# Environment Configuration for AI Career Development Platform

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=ai_career_db
DB_PORT=3306

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your_secret_key_here_change_in_production

# Email Configuration (Gmail SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# OpenAI API Configuration (for AI features)
OPENAI_API_KEY=your_openai_api_key_here

# Application Configuration
APP_NAME=AI Career Development Platform
APP_URL=http://localhost:5000
UPLOAD_FOLDER=app/static/uploads
MAX_CONTENT_LENGTH=16777216

# Session Configuration
PERMANENT_SESSION_LIFETIME=1209600
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Security
CSRF_ENABLED=True
WTF_CSRF_CHECK_DEFAULT=True

# Logging
LOG_LEVEL=DEBUG
LOG_FILE=logs/app.log

# JWT Configuration
JWT_SECRET_KEY=your_jwt_secret_key
JWT_ALGORITHM=HS256

# Password Reset Token Expiry (in hours)
PASSWORD_RESET_TOKEN_EXPIRY=24

# OTP Expiry (in minutes)
OTP_EXPIRY=10

# Pagination
ITEMS_PER_PAGE=10

# File Upload
ALLOWED_RESUME_EXTENSIONS=pdf
MAX_RESUME_SIZE=5242880

# AI Analysis Configuration
MIN_RESUME_SCORE=0
MAX_RESUME_SCORE=100
SKILL_GAP_THRESHOLD=70
